APP_ENV=development
APP_NAME="TFA Survey Platform"
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=tfa_survey
MYSQL_USER=tfa_user
MYSQL_PASSWORD=change-this-password

# Redis
REDIS_URL=redis://localhost:6379/0

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@fa.gov.sa
SMTP_PASSWORD=change-this-password
SMTP_FROM_EMAIL=noreply@fa.gov.sa
SMTP_FROM_NAME="The Financial Academy"
SMTP_TLS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# Admin seed (first run only)
FIRST_ADMIN_EMAIL=admin@fa.gov.sa
FIRST_ADMIN_PASSWORD=change-this-admin-password
